{
  "extends": "expo/tsconfig.base",
  "exclude": ["supabase/**/*"],
  "compilerOptions": {
    "typeRoots": ["./node_modules/@types", "./types"],
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@default-tamagui-config": ["src/theme/tamagui.config.ts"],
      "@screens": ["src/screens"],
      "@utils": ["src/utils"],
      "@atoms": ["src/components/atoms"],
      "@molecules": ["src/components/molecules"],
      "@organisms": ["src/components/organisms"],
      "@theme": ["src/theme/index.ts"],
      "@sentry": ["src/services/sentry/index.ts"],
      "@firebase-messaging": ["src/services/firebase-messaging/index.ts"],
      "@ai": ["src/services/ai/index.ts"],
      "@fonts": ["src/components/atoms/fonts"],
      "@icons": ["src/components/atoms/icons"],
      "@images": ["src/components/atoms/images"],
      "@stores": ["src/stores/index.ts"],
      "@constants": ["src/constants"],
      "@hooks": ["src/hooks"],
      "@i18n": ["src/i18n"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}

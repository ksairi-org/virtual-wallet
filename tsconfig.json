{
  "extends": "expo/tsconfig.base",
  "exclude": ["supabase/**/*"],
  "compilerOptions": {
    "typeRoots": ["./node_modules/@types", "./types"],
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@default-tamagui-config": ["src/theme/tamagui.config.ts"],
      "@screens": ["src/screens"],
      "@utils": ["src/utils"],
      "@atoms": ["src/components/atoms"],
      "@molecules": ["src/components/molecules"],
      "@organisms": ["src/components/organisms"],
      "@theme": ["src/theme/index.ts"],
      "@sentry": ["src/services/sentry/index.ts"],
      "@firebase-messaging": ["src/services/firebase-messaging/index.ts"],
      "@ai": ["src/services/ai/index.ts"],
      "@ksairi/react-native-hooks": ["libs/react-native-hooks"],
      "@ksairi/react-hooks": ["libs/react-hooks"],
      "@ksairi/react-native-functions": ["libs/react-native-functions"],
      "@ksairi/react-native-ui-config": ["libs/react-native-ui-config"],
      "@ksairi/typescript-functions": ["libs/typescript-functions"],
      "@ksairi/react-native-splash-view": ["libs/react-native-splash-view"],
      "@ksairi/ui-containers": ["libs/ui-containers"],
      "@ksairi/ui-touchables": ["libs/ui-touchables"],
      "@ksairi/react-auth-client": ["libs/react-auth-client"],
      "@ksairi/react-auth-core": ["libs/react-auth-core"],
      "@ksairi/react-auth-setup": ["libs/react-auth-setup"],
      "@ksairi/react-auth-storage": ["libs/react-auth-storage"],
      "@ksairi/react-auth-hooks": ["libs/react-auth-hooks"],
      "@ksairi/react-auth-storage/types": ["libs/react-auth-storage/types"],
      "@ksairi/react-native-auth-google": ["libs/react-native-auth-google"],
      "@ksairi/react-native-auth-apple": ["libs/react-native-auth-apple"],
      "@ksairi/react-form": ["libs/react-form"],
      "@ksairi/expo-image": ["libs/expo-image"],
      "@ksairi/react-query-sdk": ["libs/react-query-sdk"],
      "@fonts": ["src/components/atoms/fonts"],
      "@icons": ["src/components/atoms/icons"],
      "@images": ["src/components/atoms/images"],
      "@stores": ["src/stores/index.ts"],
      "@constants": ["src/constants"],
      "@hooks": ["src/hooks"],
      "@i18n": ["src/i18n"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
